---
---
<section id="ubicacion" class="py-20 sm:py-28 bg-[#FAF6F0]">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="inline-block text-[#C4956A] font-medium text-sm uppercase tracking-widest mb-4">Dónde encontrarnos</span>
      <h2 class="font-serif text-4xl sm:text-5xl font-bold text-[#3D2B1F] leading-tight mb-5">
        Dos puntos de venta <em class="text-[#C4956A] not-italic">en Ciudad Real</em>
      </h2>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-8 mb-10">
      
      <!-- Obrador -->
      <div class="reveal-left bg-white rounded-3xl overflow-hidden shadow-lg border border-[#F5E6D0]">
        <!-- Map embed placeholder with actual Google Maps embed -->
        <div class="h-52 bg-[#F5E6D0] relative overflow-hidden">
          <iframe
            title="Ubicación Grano a Grano Bakery Obrador"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3093.1234567890!2d-3.9344!3d38.9869!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDU5JzEyLjgiTiAzwrA1NicwMy44Ilc!5e0!3m2!1ses!2ses!4v1234567890"
            class="w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        
        <div class="p-6">
          <div class="flex items-start gap-3 mb-4">
            <span class="text-2xl mt-0.5">🏭</span>
            <div>
              <h3 class="font-serif text-xl font-bold text-[#3D2B1F]">Obrador Grano a Grano</h3>
              <p class="text-[#C4956A] text-sm font-medium">Polígono Larache</p>
            </div>
          </div>
          
          <div class="space-y-3 text-[#5C3D2E]">
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-[#C4956A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>C. Socuéllamos, 14, nave 12 · 13005 Ciudad Real</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-[#C4956A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>Mar–Vie 9:00–14:30 · Sáb 9:00–13:00</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-red-500">
              <span class="w-4 h-4 flex-shrink-0">🚫</span>
              <span>Dom y Lun: cerrado</span>
            </div>
          </div>
          
          <a
            href="https://maps.google.com/?q=C.+Socuéllamos,+14,+nave+12,+13005+Ciudad+Real"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex items-center gap-2 text-[#C4956A] hover:text-[#B07D55] text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Abrir en Google Maps
          </a>
        </div>
      </div>
      
      <!-- Carapan -->
      <div class="reveal-right bg-white rounded-3xl overflow-hidden shadow-lg border border-[#F5E6D0]">
        <div class="h-52 bg-[#F5E6D0] relative overflow-hidden">
          <iframe
            title="Ubicación Carapan Bakery Ciudad Real"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3094.0!2d-3.9232!3d38.9863!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDU5JzExLjAiTiAzwrA1NSczNS41Ilc!5e0!3m2!1ses!2ses!4v1234567891"
            class="w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        
        <div class="p-6">
          <div class="flex items-start gap-3 mb-4">
            <span class="text-2xl mt-0.5">🏪</span>
            <div>
              <h3 class="font-serif text-xl font-bold text-[#3D2B1F]">Carapan Bakery</h3>
              <p class="text-[#C4956A] text-sm font-medium">Centro de Ciudad Real</p>
            </div>
          </div>
          
          <div class="space-y-3 text-[#5C3D2E]">
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-[#C4956A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>C. Caballeros esq. C. Feria · Ciudad Real centro</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-[#C4956A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>Mar–Vie 9:00–14:30 · Sáb 9:00–13:00</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="w-4 h-4 flex-shrink-0">🏙️</span>
              <span>También puedes comprar sin pedido previo</span>
            </div>
          </div>
          
          <a
            href="https://maps.google.com/?q=C.+Caballeros+Ciudad+Real"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex items-center gap-2 text-[#C4956A] hover:text-[#B07D55] text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Abrir en Google Maps
          </a>
        </div>
      </div>
      
    </div>
    
    <!-- Phone CTA -->
    <div class="text-center reveal">
      <p class="text-[#5C3D2E] mb-3">¿Tienes dudas? Llámanos o escríbenos</p>
      <a
        href="tel:+34658542068"
        class="inline-flex items-center gap-2 font-serif text-2xl font-bold text-[#C4956A] hover:text-[#B07D55] transition-colors"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        658 54 20 68
      </a>
    </div>
    
  </div>
</section>
