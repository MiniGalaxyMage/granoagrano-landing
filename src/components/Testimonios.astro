---
const testimonios = [
  {
    nombre: "María García",
    texto: "Desde que descubrí Grano a Grano no puedo volver al pan del supermercado. La hogaza de la casa es simplemente increíble — corteza crujiente, miga perfecta y aguanta 4-5 días sin perder calidad. Carlos y Esther son un tesoro para Ciudad Real.",
    estrellas: 5,
    fecha: "Hace 2 semanas",
    inicial: "M",
  },
  {
    nombre: "Antonio Ruiz",
    texto: "Un obrador que ha revolucionado el pan en Ciudad Real. Los cruasanes son dignos de cualquier pastelería parisina, y el pan de masa madre es como el que hacían los abuelos, pero mejor. El trato personal marca la diferencia.",
    estrellas: 5,
    fecha: "Hace 1 mes",
    inicial: "A",
  },
  {
    nombre: "Laura Fernández",
    texto: "Pedimos todos los viernes. Los Cinnamon Rolls del sábado son una locura — mi familia entera se ha convertido en incondicional. El servicio de delivery es puntual y el pan llega perfecto. 100% recomendable.",
    estrellas: 5,
    fecha: "Hace 3 semanas",
    inicial: "L",
  },
];
---

<section id="testimonios" class="py-20 sm:py-28 bg-[#3D2B1F] relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-[#C4956A]/10"></div>
  <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full bg-[#D4A853]/10"></div>
  
  <div class="max-w-6xl mx-auto px-6 relative">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="inline-block text-[#F5C97A] font-medium text-sm uppercase tracking-widest mb-4">Lo que dicen nuestros clientes</span>
      <h2 class="font-serif text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        4.9/5 en Google
      </h2>
      <div class="flex justify-center gap-1 mb-4">
        {[1,2,3,4,5].map(() => (
          <svg class="w-7 h-7 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <p class="text-[#F5E6D0]/70 text-lg">Cientos de reseñas de clientes de Ciudad Real</p>
    </div>
    
    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {testimonios.map((t, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-[#2C1A0E]/60 backdrop-blur-sm border border-[#C4956A]/20 rounded-2xl p-7 hover:border-[#C4956A]/50 transition-colors duration-300`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          
          <!-- Text -->
          <p class="text-[#F5E6D0]/85 leading-relaxed mb-6 text-sm italic">
            "{t.texto}"
          </p>
          
          <!-- Author -->
          <div class="flex items-center gap-3 border-t border-[#C4956A]/15 pt-4">
            <div class="w-9 h-9 rounded-full bg-[#C4956A] flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
              {t.inicial}
            </div>
            <div>
              <div class="text-white font-medium text-sm">{t.nombre}</div>
              <div class="text-[#F5E6D0]/50 text-xs">{t.fecha} · Google</div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Google Badge -->
    <div class="text-center mt-10 reveal">
      <a
        href="https://maps.google.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[#F5E6D0]/60 hover:text-[#F5E6D0]/90 text-sm transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Ver todas las reseñas en Google Maps
      </a>
    </div>
    
  </div>
</section>
