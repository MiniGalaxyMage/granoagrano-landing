---
---
<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 hidden md:bottom-6 md:left-6 md:right-auto md:max-w-sm"
  role="dialog"
  aria-label="Aviso de cookies"
  aria-modal="true"
>
  <div class="bg-white border border-[#F5E6D0] rounded-2xl shadow-2xl p-5 mx-4 md:mx-0">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl flex-shrink-0">🍪</span>
      <div>
        <h3 class="font-serif font-bold text-[#3D2B1F] text-base mb-1">Cookies</h3>
        <p class="text-[#5C3D2E] text-sm leading-relaxed">
          Usamos cookies técnicas esenciales para el funcionamiento de la web. No usamos cookies de seguimiento ni publicidad.
          <a href="/cookies" class="text-[#C4956A] hover:underline ml-0.5">Más información</a>
        </p>
      </div>
    </div>
    <div class="flex gap-3">
      <button
        id="cookie-accept"
        class="flex-1 bg-[#C4956A] hover:bg-[#B07D55] text-white text-sm font-semibold py-2.5 rounded-xl transition-colors"
      >
        Aceptar
      </button>
      <a
        href="/privacidad"
        class="flex-1 text-center border border-[#E8D5BE] hover:border-[#C4956A] text-[#5C3D2E] text-sm font-medium py-2.5 rounded-xl transition-colors"
      >
        Política
      </a>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  
  // Show banner if not accepted
  if (!localStorage.getItem('cookies-accepted')) {
    setTimeout(() => {
      banner?.classList.remove('hidden');
    }, 1500);
  }
  
  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookies-accepted', 'true');
    banner?.classList.add('hidden');
  });
</script>
