---
const productos = [
  {
    nombre: "Pan de Masa Madre",
    emoji: "🍞",
    descripcion: "El corazón de Grano a Grano. 8 variedades de hogazas artesanales elaboradas con masa madre de cultivo propio y fermentación de 24-30 horas.",
    variedades: ["Hogaza de la Casa", "Semillas (lino, girasol, sésamo)", "Queso Manchego", "Nueces y Pasas", "100% Espelta", "100% Integral", "Aceitunas", "Volkonbrot"],
    imagen: "https://images.unsplash.com/photo-1586444248902-2f64eddc13df?w=600&q=80&fit=crop",
    badge: "Especialidad",
    badgeColor: "bg-[#C4956A] text-white",
  },
  {
    nombre: "Bollería Artesana",
    emoji: "🥐",
    descripcion: "Hojaldre laminado a mano con mantequilla real. Desde cruasanes de corteza perfecta hasta Cinnamon Rolls y Chelsea Buns que huelen a hogar.",
    variedades: ["Cruasanes artesanos", "Cinnamon Rolls", "Chelsea Buns", "Cookies sal Maldon", "Brownies", "Magdalenas"],
    imagen: "https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=600&q=80&fit=crop",
    badge: "Imprescindible",
    badgeColor: "bg-[#7A8B6F] text-white",
  },
  {
    nombre: "Pan de Levadura",
    emoji: "🥖",
    descripcion: "Para quien busca la textura clásica: chapatas aireadas, pan inglés de molde natural e integral, y los Burger Buns brioche de los jueves y viernes.",
    variedades: ["Chapatas", "Pan Inglés de molde", "Pan Inglés integral", "Burger Buns brioche (jue-vie)"],
    imagen: "https://images.unsplash.com/photo-1574085733277-851d9d856a3a?w=600&q=80&fit=crop",
    badge: "Cada semana",
    badgeColor: "bg-[#D4A853] text-[#3D2B1F]",
  },
];
---

<section id="productos" class="py-20 sm:py-28 bg-[#F5EDE0]">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="inline-block text-[#C4956A] font-medium text-sm uppercase tracking-widest mb-4">Lo que horneamos</span>
      <h2 class="font-serif text-4xl sm:text-5xl font-bold text-[#3D2B1F] leading-tight mb-5">
        Panes que se hacen <em class="text-[#C4956A] not-italic">con tiempo y cariño</em>
      </h2>
      <p class="text-[#5C3D2E] text-lg">
        Pedido por WhatsApp con 48h de antelación. Siempre recién horneado.
      </p>
    </div>
    
    <!-- Cards grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {productos.map((p, i) => (
        <div class={`reveal reveal-delay-${i + 1} group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-400 hover:-translate-y-2`}>
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={p.imagen}
              alt={p.nombre}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <span class={`absolute top-4 left-4 text-xs font-bold px-3 py-1 rounded-full ${p.badgeColor}`}>
              {p.badge}
            </span>
          </div>
          
          <!-- Content -->
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">{p.emoji}</span>
              <h3 class="font-serif text-xl font-bold text-[#3D2B1F]">{p.nombre}</h3>
            </div>
            <p class="text-[#5C3D2E] text-sm leading-relaxed mb-4">{p.descripcion}</p>
            
            <!-- Varieties -->
            <ul class="space-y-1.5">
              {p.variedades.slice(0, 4).map(v => (
                <li class="flex items-center gap-2 text-sm text-[#5C3D2E]">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#C4956A] flex-shrink-0"></span>
                  {v}
                </li>
              ))}
              {p.variedades.length > 4 && (
                <li class="text-xs text-[#C4956A] font-medium mt-1">
                  +{p.variedades.length - 4} variedades más
                </li>
              )}
            </ul>
          </div>
        </div>
      ))}
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-12 reveal">
      <a
        href="https://wa.me/34658542068"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#C4956A] hover:bg-[#B07D55] text-white font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hacer mi pedido por WhatsApp
      </a>
    </div>
    
  </div>
</section>
