---
<section class="bg-[#3D2B1F] py-10 sm:py-14">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      
      <div class="reveal reveal-delay-1">
        <div class="flex justify-center mb-2">
          <span class="text-yellow-400 text-2xl">⭐⭐⭐⭐⭐</span>
        </div>
        <div class="font-serif text-3xl font-bold text-[#F5C97A]">4.9/5</div>
        <p class="text-[#F5E6D0]/70 text-sm mt-1">Valoración Google</p>
      </div>
      
      <div class="reveal reveal-delay-2">
        <div class="font-serif text-3xl font-bold text-[#F5C97A]">Desde 2021</div>
        <p class="text-[#F5E6D0]/70 text-sm mt-1">Nacidos durante el confinamiento</p>
      </div>
      
      <div class="reveal reveal-delay-3">
        <div class="font-serif text-3xl font-bold text-[#F5C97A]">8 tipos</div>
        <p class="text-[#F5E6D0]/70 text-sm mt-1">Hogazas artesanales de masa madre</p>
      </div>
      
      <div class="reveal reveal-delay-4">
        <div class="font-serif text-3xl font-bold text-[#F5C97A]">3 ingredientes</div>
        <p class="text-[#F5E6D0]/70 text-sm mt-1">Harina, agua y sal. Nada más.</p>
      </div>
      
    </div>
  </div>
</section>
