---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Grano a Grano Bakery — Pan Artesanal de Masa Madre en Ciudad Real",
  description = "Panadería artesana en Ciudad Real. Pan de masa madre de cultivo propio, fermentación lenta, sin aditivos. Hogaza de la Casa, bollería artesana y más. Pedidos por WhatsApp.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://granoagranoobrador.com");

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "Bakery"],
      "@id": "https://granoagranoobrador.com/#business",
      "name": "Grano a Grano Bakery",
      "description": "Obrador artesanal de pan de masa madre en Ciudad Real. Fermentación lenta, sin aditivos, solo harina, agua y sal.",
      "url": "https://granoagranoobrador.com",
      "telephone": "+34658542068",
      "email": "",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "C. Socuéllamos, 14, nave 12",
        "addressLocality": "Ciudad Real",
        "postalCode": "13005",
        "addressRegion": "Castilla-La Mancha",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 38.9869,
        "longitude": -3.9300
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "14:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "13:00"
        }
      ],
      "priceRange": "€€",
      "servesCuisine": "Panadería artesanal",
      "hasMap": "https://maps.google.com/?q=C.+Soc%C3%BCellamos,+14,+nave+12,+13005+Ciudad+Real",
      "sameAs": [
        "https://www.instagram.com/granoagranobakery"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "100",
        "bestRating": "5"
      },
      "founder": [
        {
          "@type": "Person",
          "name": "Carlos Tirado Gascón"
        },
        {
          "@type": "Person",
          "name": "Esther Sanjurjo"
        }
      ],
      "foundingDate": "2021"
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#C4956A" />
    
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="pan artesanal Ciudad Real, masa madre Ciudad Real, panadería artesanal Ciudad Real, obrador pan Ciudad Real, pan sin aditivos, Grano a Grano Bakery, Carapan Ciudad Real" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Grano a Grano Bakery" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=1200&h=630&fit=crop" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=1200&h=630&fit=crop" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    
    <!-- Scroll reveal script -->
    <script>
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -40px 0px'
      });

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => {
        revealObserver.observe(el);
      });
    </script>
  </body>
</html>
